# ─── Uzum Market Seller API ───
UZUM_API_BASE_URL=https://api-seller.uzum.uz/api/seller-openapi
UZUM_API_TOKEN=your_token_here
UZUM_API_TIMEOUT=30

# Для неофициального API (отзывы)
UZUM_SELLER_PANEL_URL=https://api-seller.uzum.uz

# ─── OAuth2 (Seller Panel авторизация) ───
UZUM_OAUTH_TOKEN_URL=https://api-seller.uzum.uz/api/oauth/token
UZUM_OAUTH_CLIENT_ID=b2b-front
UZUM_OAUTH_CLIENT_SECRET=clientSecret

# ─── Авто-подтверждение заказов ───
UZUM_AUTO_CONFIRM_ENABLED=true
UZUM_AUTO_CONFIRM_INTERVAL=15

# ─── ИИ авто-ответ на отзывы ───
UZUM_AUTO_REPLY_ENABLED=false
UZUM_REVIEW_AI_PROVIDER=anthropic
UZUM_REVIEW_AI_API_KEY=your_anthropic_api_key
UZUM_REVIEW_AI_MODEL=claude-sonnet-4-20250514
UZUM_AUTO_REPLY_INTERVAL=30
